{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://imagefreely.com",
          "http://localhost:4175",
          "http://localhost:4177",
          "http://127.0.0.1:4175",
          "http://127.0.0.1:4177"
        ],
        "methods": [
          "GET",
          "HEAD"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "Cache-Control",
        "Content-Length",
        "Content-Type",
        "ETag"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
